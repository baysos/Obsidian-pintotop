{
  "name": "pin-to-top",
  "version": "1.0.4",
  "description": "Pin files and folders to the top of their current folder in the Obsidian file explorer.",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "pin",
    "file-explorer",
    "folder"
  ],
  "author": "baysos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baysos/Obsidian-pintotop.git"
  },
  "bugs": {
    "url": "https://github.com/baysos/Obsidian-pintotop/issues"
  },
  "homepage": "https://github.com/baysos/Obsidian-pintotop#readme",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.0",
    "obsidian": "^1.5.12",
    "typescript": "^5.4.3"
  }
}
